# Nexus Control environment (copy to .env for local dev)

# Shared auth secret (must match between web and api)
BETTER_AUTH_SECRET=dev-insecure-secret-change-me

# Postgres
DATABASE_URL=postgres://nexus:nexus@localhost:5432/nexus

# Redis
REDIS_ADDR=localhost:6379

# API
HTTP_ADDR=:8080
GRPC_ADDR=:9090
AUTH_DEV_MODE=true
GRPC_TLS_DISABLED=true

# Web
BETTER_AUTH_URL=http://localhost:3000
API_INTERNAL_URL=http://localhost:8080
NEXT_PUBLIC_API_URL=/api/control
